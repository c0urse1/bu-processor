# ============================================================================
# BU-PROCESSOR ENVIRONMENT CONFIGURATION
# ============================================================================
# Diese Datei zeigt alle verfügbaren Umgebungsvariablen für die Konfiguration.
# Kopiere diese Datei zu .env und setze deine gewünschten Werte.

# ============================================================================
# BASIC ENVIRONMENT SETTINGS
# ============================================================================

# Application Environment (development, staging, production)
BU_PROCESSOR_ENVIRONMENT=development

# Debug Mode (true/false)
BU_PROCESSOR_DEBUG=true

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
BU_PROCESSOR_LOG_LEVEL=INFO

# Application Info
BU_PROCESSOR_APP_NAME=BU-Processor
BU_PROCESSOR_VERSION=3.0.0

# ============================================================================
# ML MODEL CONFIGURATION
# ============================================================================

# Model Paths
BU_PROCESSOR_ML_MODEL__MODEL_PATH=models/trained_bu_model
BU_PROCESSOR_ML_MODEL__SENTENCE_TRANSFORMER_MODEL=paraphrase-multilingual-MiniLM-L12-v2
BU_PROCESSOR_ML_MODEL__MODEL_NAME=bu-classifier-v1

# Model Parameters
BU_PROCESSOR_ML_MODEL__MAX_SEQUENCE_LENGTH=512
BU_PROCESSOR_ML_MODEL__CONFIDENCE_THRESHOLD=0.8
BU_PROCESSOR_ML_MODEL__USE_GPU=true

# ============================================================================
# PDF PROCESSING CONFIGURATION
# ============================================================================

# Extraction Settings
BU_PROCESSOR_PDF_PROCESSING__EXTRACTION_METHOD=pymupdf
BU_PROCESSOR_PDF_PROCESSING__MAX_PDF_SIZE_MB=50
BU_PROCESSOR_PDF_PROCESSING__MAX_PDF_PAGES=100

# Text Processing
BU_PROCESSOR_PDF_PROCESSING__TEXT_CLEANUP=true
BU_PROCESSOR_PDF_PROCESSING__MIN_EXTRACTED_TEXT_LENGTH=10
BU_PROCESSOR_PDF_PROCESSING__NORMALIZE_WHITESPACE=true
BU_PROCESSOR_PDF_PROCESSING__AUTO_DETECT_LANGUAGE=false

# Batch Processing
BU_PROCESSOR_PDF_PROCESSING__MAX_BATCH_PDF_COUNT=20
BU_PROCESSOR_PDF_PROCESSING__FALLBACK_CHAIN=true
BU_PROCESSOR_PDF_PROCESSING__EXTRACT_METADATA=true

# Cache Settings
BU_PROCESSOR_PDF_PROCESSING__CACHE_DIR=cache/pdf_extractions
BU_PROCESSOR_PDF_PROCESSING__ENABLE_CACHE=true

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Server Settings
BU_PROCESSOR_API__HOST=0.0.0.0
BU_PROCESSOR_API__PORT=8000

# Monitoring
BU_PROCESSOR_API__PROMETHEUS_METRICS_PORT=9100

# Security (WICHTIG: Setze diese in Production!)
# BU_PROCESSOR_API__API_KEY=your-secure-api-key-here
# BU_PROCESSOR_API__SECRET_KEY=your-super-secret-key-here

# ============================================================================
# VECTOR DATABASE (PINECONE) CONFIGURATION
# ============================================================================

# Enable Vector Database Integration
BU_PROCESSOR_VECTOR_DB__ENABLE_VECTOR_DB=false

# Pinecone Settings (nur wenn enabled)
# BU_PROCESSOR_VECTOR_DB__PINECONE_API_KEY=pc-your-pinecone-api-key
BU_PROCESSOR_VECTOR_DB__PINECONE_ENVIRONMENT=us-west1-gcp-free
BU_PROCESSOR_VECTOR_DB__PINECONE_INDEX_NAME=bu-processor

# Embedding Settings
BU_PROCESSOR_VECTOR_DB__EMBEDDING_DIMENSION=384
BU_PROCESSOR_VECTOR_DB__EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
BU_PROCESSOR_VECTOR_DB__MAX_BATCH_SIZE=100

# ============================================================================
# OPENAI CHATBOT CONFIGURATION
# ============================================================================

# Enable Chatbot Integration
BU_PROCESSOR_OPENAI__ENABLE_CHATBOT=false

# OpenAI Settings (nur wenn enabled)
# BU_PROCESSOR_OPENAI__OPENAI_API_KEY=sk-your-openai-api-key
BU_PROCESSOR_OPENAI__OPENAI_MODEL=gpt-3.5-turbo
BU_PROCESSOR_OPENAI__MAX_TOKENS=1000
BU_PROCESSOR_OPENAI__TEMPERATURE=0.7

# ============================================================================
# ENVIRONMENT-SPECIFIC EXAMPLES
# ============================================================================

# DEVELOPMENT Environment Example:
# BU_PROCESSOR_ENVIRONMENT=development
# BU_PROCESSOR_DEBUG=true
# BU_PROCESSOR_LOG_LEVEL=DEBUG
# BU_PROCESSOR_PDF_PROCESSING__MAX_PDF_SIZE_MB=100
# BU_PROCESSOR_PDF_PROCESSING__MAX_BATCH_PDF_COUNT=50

# STAGING Environment Example:
# BU_PROCESSOR_ENVIRONMENT=staging
# BU_PROCESSOR_DEBUG=false
# BU_PROCESSOR_LOG_LEVEL=INFO
# BU_PROCESSOR_PDF_PROCESSING__MAX_PDF_SIZE_MB=50
# BU_PROCESSOR_API__SECRET_KEY=staging-secret-key

# PRODUCTION Environment Example:
# BU_PROCESSOR_ENVIRONMENT=production
# BU_PROCESSOR_DEBUG=false
# BU_PROCESSOR_LOG_LEVEL=WARNING
# BU_PROCESSOR_PDF_PROCESSING__MAX_PDF_SIZE_MB=25
# BU_PROCESSOR_PDF_PROCESSING__MAX_BATCH_PDF_COUNT=10
# BU_PROCESSOR_PDF_PROCESSING__ENABLE_CACHE=false
# BU_PROCESSOR_API__SECRET_KEY=super-secure-production-key
# BU_PROCESSOR_API__API_KEY=production-api-key

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. Präfixe: Alle Variablen beginnen mit BU_PROCESSOR_
# 2. Nested Config: Verwende __ für verschachtelte Konfiguration
# 3. Sicherheit: Setze niemals echte API Keys in diese .env.example Datei
# 4. Environment: Die meisten Settings werden automatisch je nach Environment angepasst
# 5. Validierung: Ungültige Werte werden automatisch validiert und korrigiert
